# Dependencies
node_modules/

# Data files (users can regenerate if needed)
# Uncomment the line below to exclude chunks.json from git
# data/chunks.json

raw/*.pdf
raw/*.zip

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# SpecKit (may contain credentials)
.claude/

# Intermediate extraction data (tracked via Git LFS)
# data/intermediate/*.jsonl  # tracked by LFS
# data/corpus/*.db            # tracked by LFS
data/corpus/*.db-shm
data/corpus/*.db-wal
data/pdfs/*.pdf
data/pdfs/manifest.json
__pycache__/
scripts/__pycache__/
