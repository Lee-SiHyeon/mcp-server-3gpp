# 3GPP MCP Server — Production Configuration

# --- Server ---
PORT=3000

# --- Authentication ---
# Set to enable API key auth. Leave empty for open access (not recommended for public servers).
API_KEY=

# --- CORS ---
# Allowed origin(s). Use comma-separated for multiple. Default: *
CORS_ORIGIN=*

# --- Rate Limiting ---
# Time window in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP
RATE_LIMIT_MAX=100

# --- Database ---
# Override default DB path (default: data/corpus/3gpp.db)
THREEGPP_DB_PATH=
