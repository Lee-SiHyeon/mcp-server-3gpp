# 3GPP MCP Server — Production Configuration

# --- Server ---
PORT=3000

# --- Authentication ---
# Production HTTP requires API_KEY unless ALLOW_OPEN_HTTP=true is set explicitly.
API_KEY=
ALLOW_OPEN_HTTP=false

# --- CORS ---
# Allowed origin(s). Use comma-separated for multiple. Default: *
CORS_ORIGIN=*

# --- Rate Limiting ---
# Time window in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP
RATE_LIMIT_MAX=100
# Maximum JSON request body size in bytes
MAX_BODY_BYTES=1048576
# Trust X-Forwarded-For only when running behind a trusted proxy.
TRUST_PROXY=false

# --- Database ---
# Override default DB path (default: data/corpus/3gpp.db)
THREEGPP_DB_PATH=
