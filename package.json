{
  "name": "mcp-server-3gpp",
  "version": "1.1.0",
  "description": "MCP Server for 3GPP and IETF RFC specification search — 207 specs, 66,109 sections, hybrid BM25+vector search, cross-spec reference graph. Pre-built SQLite corpus via Git LFS.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mcp-server-3gpp": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "node scripts/postinstall.js",
    "download-pdfs": "node scripts/download-pdfs.js",
    "prepare-data": "node scripts/prepare-data.js",
    "setup": "npm run download-pdfs && npm run prepare-data",
    "test": "node --test test/*.test.js",
    "test:legacy": "node test_speckit_userstories.js",
    "validate": "node validate.js",
    "benchmark": "node scripts/benchmark.js",
    "corpus:migrate": "node scripts/migrate_legacy_json_to_sqlite.js",
    "corpus:build": "node scripts/build_corpus.js",
    "corpus:rebuild": "node scripts/build_corpus.js --rebuild",
    "corpus:download": "python scripts/download_etsi_specs.py --latest-only",
    "corpus:extract": "python scripts/extract_all.py",
    "corpus:full": "npm run corpus:download && npm run corpus:extract && npm run corpus:build",
    "rfc:download": "python scripts/download_rfc.py",
    "rfc:extract": "python scripts/extract_rfc_structure.py",
    "rfc:load": "node src/ingest/loadRfcSections.js",
    "rfc:pipeline": "bash scripts/run_rfc_pipeline.sh",
    "rfc:all": "bash scripts/run_rfc_pipeline.sh --all"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "3gpp",
    "lte",
    "5g",
    "nr",
    "nas",
    "emm",
    "5gmm",
    "rf",
    "rct",
    "ims",
    "rse",
    "protocol",
    "usim",
    "usat",
    "nad",
    "telecom",
    "ai",
    "copilot"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lee-SiHyeon/mcp-server-3gpp.git"
  },
  "homepage": "https://github.com/Lee-SiHyeon/mcp-server-3gpp#readme",
  "bugs": {
    "url": "https://github.com/Lee-SiHyeon/mcp-server-3gpp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.8.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.1.13"
  }
}
